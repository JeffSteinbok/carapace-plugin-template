{
  "name": "my-plugin",
  "version": "1.0.0",
  "description": "🦞🐚 An OpenClaw plugin built with Carapace",
  "type": "module",
  "bin": {
    "my-plugin": "./dist/bin/my-plugin.js"
  },
  "scripts": {
    "build": "tsup && carapace-generate-cli --entry ./dist/plugin.js --out ./dist/bin",
    "test": "vitest run"
  },
  "dependencies": {
    "carapace-plugin-sdk": "github:JeffSteinbok/carapace-plugin-sdk#main",
    "@sinclair/typebox": "^0.34.48"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8.3.0",
    "typescript": "^5.7",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "openclaw": "^2026.4.23"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./dist/adapter.js"
    ]
  },
  "license": "MIT"
}
